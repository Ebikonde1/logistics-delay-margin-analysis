<?xml version='1.0' encoding='utf-8' ?>
<workbook original-version='18.1' source-build='2022.1.0 (20221.22.0322.1035)' source-platform='win' version='18.1' xmlns:user='http://www.tableausoftware.com/xml/user'>
  <preferences>
    <preference name='ui.encoding.shelf.height' value='24' />
    <preference name='ui.shelf.height' value='26' />
  </preferences>
  <datasources>
    <datasource caption='depot_performance' inline='true' name='federated.depot' version='18.1'>
      <connection class='federated'>
        <named-connections>
          <named-connection caption='depot_performance' name='textscan.depot'>
            <connection class='textscan' directory='C:/Users/DELL/logistics-portfolio-project/outputs' filename='depot_performance.csv' password='' server='' />
          </named-connection>
        </named-connections>
        <relation connection='textscan.depot' name='depot_performance.csv' table='[depot_performance#csv]' type='table' />
      </connection>
      <column datatype='string' name='[depot_code]' role='dimension' type='nominal' />
      <column datatype='string' name='[depot_name]' role='dimension' type='nominal' />
      <column datatype='real' name='[lat]' role='measure' type='quantitative' semantic-role='[Geographical].[Latitude]' />
      <column datatype='real' name='[lon]' role='measure' type='quantitative' semantic-role='[Geographical].[Longitude]' />
      <column datatype='integer' name='[shipments]' role='measure' type='quantitative' />
      <column datatype='real' name='[on_time_pct]' role='measure' type='quantitative' />
      <column datatype='real' name='[avg_delay_when_late_min]' role='measure' type='quantitative' />
      <column datatype='real' name='[revenue_gbp]' role='measure' type='quantitative' />
      <column datatype='real' name='[margin_gbp]' role='measure' type='quantitative' />
      <column datatype='real' name='[margin_pct]' role='measure' type='quantitative' />
      <column datatype='real' name='[sla_credits_gbp]' role='measure' type='quantitative' />
      <column datatype='real' name='[cost_per_mile_gbp]' role='measure' type='quantitative' />
    </datasource>
    <datasource caption='route_performance' inline='true' name='federated.route' version='18.1'>
      <connection class='federated'>
        <named-connections>
          <named-connection caption='route_performance' name='textscan.route'>
            <connection class='textscan' directory='C:/Users/DELL/logistics-portfolio-project/outputs' filename='route_performance.csv' password='' server='' />
          </named-connection>
        </named-connections>
        <relation connection='textscan.route' name='route_performance.csv' table='[route_performance#csv]' type='table' />
      </connection>
      <column datatype='string' name='[route_id]' role='dimension' type='nominal' />
      <column datatype='string' name='[depot_code]' role='dimension' type='nominal' />
      <column datatype='string' name='[delivery_region]' role='dimension' type='nominal' />
      <column datatype='real' name='[region_lat]' role='measure' type='quantitative' semantic-role='[Geographical].[Latitude]' />
      <column datatype='real' name='[region_lon]' role='measure' type='quantitative' semantic-role='[Geographical].[Longitude]' />
      <column datatype='integer' name='[shipments]' role='measure' type='quantitative' />
      <column datatype='real' name='[on_time_pct]' role='measure' type='quantitative' />
      <column datatype='integer' name='[late_shipments]' role='measure' type='quantitative' />
      <column datatype='real' name='[avg_miles]' role='measure' type='quantitative' />
      <column datatype='real' name='[revenue_per_mile]' role='measure' type='quantitative' />
      <column datatype='real' name='[cost_per_mile]' role='measure' type='quantitative' />
      <column datatype='real' name='[margin_gbp]' role='measure' type='quantitative' />
      <column datatype='real' name='[margin_pct]' role='measure' type='quantitative' />
      <column datatype='real' name='[sla_credits_gbp]' role='measure' type='quantitative' />
    </datasource>
    <datasource caption='service_margin' inline='true' name='federated.svc' version='18.1'>
      <connection class='federated'>
        <named-connections>
          <named-connection caption='service_margin' name='textscan.svc'>
            <connection class='textscan' directory='C:/Users/DELL/logistics-portfolio-project/outputs' filename='service_margin.csv' password='' server='' />
          </named-connection>
        </named-connections>
        <relation connection='textscan.svc' name='service_margin.csv' table='[service_margin#csv]' type='table' />
      </connection>
      <column datatype='string' name='[service_level]' role='dimension' type='nominal' />
      <column datatype='string' name='[distance_band]' role='dimension' type='nominal' />
      <column datatype='integer' name='[shipments]' role='measure' type='quantitative' />
      <column datatype='real' name='[revenue_per_mile]' role='measure' type='quantitative' />
      <column datatype='real' name='[cost_per_mile]' role='measure' type='quantitative' />
      <column datatype='real' name='[margin_gbp]' role='measure' type='quantitative' />
      <column datatype='real' name='[margin_pct]' role='measure' type='quantitative' />
    </datasource>
    <datasource caption='monthly_trend' inline='true' name='federated.month' version='18.1'>
      <connection class='federated'>
        <named-connections>
          <named-connection caption='monthly_trend' name='textscan.month'>
            <connection class='textscan' directory='C:/Users/DELL/logistics-portfolio-project/outputs' filename='monthly_trend.csv' password='' server='' />
          </named-connection>
        </named-connections>
        <relation connection='textscan.month' name='monthly_trend.csv' table='[monthly_trend#csv]' type='table' />
      </connection>
      <column datatype='string' name='[month]' role='dimension' type='ordinal' />
      <column datatype='integer' name='[shipments]' role='measure' type='quantitative' />
      <column datatype='real' name='[on_time_pct]' role='measure' type='quantitative' />
      <column datatype='real' name='[revenue_gbp]' role='measure' type='quantitative' />
      <column datatype='real' name='[margin_gbp]' role='measure' type='quantitative' />
      <column datatype='real' name='[sla_credits_gbp]' role='measure' type='quantitative' />
    </datasource>
  </datasources>
  <worksheets>
    <worksheet name='Late-Delivery Map'>
      <table>
        <view>
          <datasources>
            <datasource caption='route_performance' name='federated.route' />
          </datasources>
          <datasource-dependencies datasource='federated.route'>
            <column datatype='string' name='[delivery_region]' role='dimension' type='nominal' />
            <column datatype='real' name='[region_lat]' role='measure' type='quantitative' semantic-role='[Geographical].[Latitude]' />
            <column datatype='real' name='[region_lon]' role='measure' type='quantitative' semantic-role='[Geographical].[Longitude]' />
            <column datatype='real' name='[on_time_pct]' role='measure' type='quantitative' />
            <column datatype='integer' name='[late_shipments]' role='measure' type='quantitative' />
            <column-instance column='[delivery_region]' derivation='None' name='[none:delivery_region:nk]' pivot='key' type='nominal' />
            <column-instance column='[region_lat]' derivation='Avg' name='[avg:region_lat:qk]' pivot='key' type='quantitative' />
            <column-instance column='[region_lon]' derivation='Avg' name='[avg:region_lon:qk]' pivot='key' type='quantitative' />
            <column-instance column='[on_time_pct]' derivation='Avg' name='[avg:on_time_pct:qk]' pivot='key' type='quantitative' />
            <column-instance column='[late_shipments]' derivation='Sum' name='[sum:late_shipments:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Circle' />
            <encodings>
              <color column='[federated.route].[avg:on_time_pct:qk]' />
              <size column='[federated.route].[sum:late_shipments:qk]' />
              <lod column='[federated.route].[none:delivery_region:nk]' />
            </encodings>
          </pane>
        </panes>
        <rows>[federated.route].[avg:region_lat:qk]</rows>
        <cols>[federated.route].[avg:region_lon:qk]</cols>
      </table>
    </worksheet>
    <worksheet name='Depot On-Time'>
      <table>
        <view>
          <datasources>
            <datasource caption='depot_performance' name='federated.depot' />
          </datasources>
          <datasource-dependencies datasource='federated.depot'>
            <column datatype='string' name='[depot_name]' role='dimension' type='nominal' />
            <column datatype='real' name='[on_time_pct]' role='measure' type='quantitative' />
            <column datatype='real' name='[sla_credits_gbp]' role='measure' type='quantitative' />
            <column-instance column='[depot_name]' derivation='None' name='[none:depot_name:nk]' pivot='key' type='nominal' />
            <column-instance column='[on_time_pct]' derivation='Sum' name='[sum:on_time_pct:qk]' pivot='key' type='quantitative' />
            <column-instance column='[sla_credits_gbp]' derivation='Sum' name='[sum:sla_credits_gbp:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Bar' />
            <encodings>
              <color column='[federated.depot].[sum:sla_credits_gbp:qk]' />
            </encodings>
          </pane>
        </panes>
        <rows>[federated.depot].[none:depot_name:nk]</rows>
        <cols>[federated.depot].[sum:on_time_pct:qk]</cols>
      </table>
    </worksheet>
    <worksheet name='Cost vs SLA Scatter'>
      <table>
        <view>
          <datasources>
            <datasource caption='route_performance' name='federated.route' />
          </datasources>
          <datasource-dependencies datasource='federated.route'>
            <column datatype='string' name='[route_id]' role='dimension' type='nominal' />
            <column datatype='real' name='[cost_per_mile]' role='measure' type='quantitative' />
            <column datatype='real' name='[on_time_pct]' role='measure' type='quantitative' />
            <column datatype='integer' name='[shipments]' role='measure' type='quantitative' />
            <column datatype='real' name='[margin_pct]' role='measure' type='quantitative' />
            <column-instance column='[route_id]' derivation='None' name='[none:route_id:nk]' pivot='key' type='nominal' />
            <column-instance column='[cost_per_mile]' derivation='Avg' name='[avg:cost_per_mile:qk]' pivot='key' type='quantitative' />
            <column-instance column='[on_time_pct]' derivation='Avg' name='[avg:on_time_pct:qk]' pivot='key' type='quantitative' />
            <column-instance column='[shipments]' derivation='Sum' name='[sum:shipments:qk]' pivot='key' type='quantitative' />
            <column-instance column='[margin_pct]' derivation='Avg' name='[avg:margin_pct:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Circle' />
            <encodings>
              <color column='[federated.route].[avg:margin_pct:qk]' />
              <size column='[federated.route].[sum:shipments:qk]' />
              <lod column='[federated.route].[none:route_id:nk]' />
            </encodings>
          </pane>
        </panes>
        <rows>[federated.route].[avg:on_time_pct:qk]</rows>
        <cols>[federated.route].[avg:cost_per_mile:qk]</cols>
      </table>
    </worksheet>
    <worksheet name='Margin Matrix'>
      <table>
        <view>
          <datasources>
            <datasource caption='service_margin' name='federated.svc' />
          </datasources>
          <datasource-dependencies datasource='federated.svc'>
            <column datatype='string' name='[service_level]' role='dimension' type='nominal' />
            <column datatype='string' name='[distance_band]' role='dimension' type='nominal' />
            <column datatype='real' name='[margin_pct]' role='measure' type='quantitative' />
            <column-instance column='[service_level]' derivation='None' name='[none:service_level:nk]' pivot='key' type='nominal' />
            <column-instance column='[distance_band]' derivation='None' name='[none:distance_band:nk]' pivot='key' type='nominal' />
            <column-instance column='[margin_pct]' derivation='Sum' name='[sum:margin_pct:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Square' />
            <encodings>
              <color column='[federated.svc].[sum:margin_pct:qk]' />
              <text column='[federated.svc].[sum:margin_pct:qk]' />
            </encodings>
          </pane>
        </panes>
        <rows>[federated.svc].[none:service_level:nk]</rows>
        <cols>[federated.svc].[none:distance_band:nk]</cols>
      </table>
    </worksheet>
    <worksheet name='Peak Trend'>
      <table>
        <view>
          <datasources>
            <datasource caption='monthly_trend' name='federated.month' />
          </datasources>
          <datasource-dependencies datasource='federated.month'>
            <column datatype='string' name='[month]' role='dimension' type='ordinal' />
            <column datatype='real' name='[on_time_pct]' role='measure' type='quantitative' />
            <column-instance column='[month]' derivation='None' name='[none:month:ok]' pivot='key' type='ordinal' />
            <column-instance column='[on_time_pct]' derivation='Sum' name='[sum:on_time_pct:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Line' />
          </pane>
        </panes>
        <rows>[federated.month].[sum:on_time_pct:qk]</rows>
        <cols>[federated.month].[none:month:ok]</cols>
      </table>
    </worksheet>
  </worksheets>
  <dashboards>
    <dashboard name='Delivery &amp; Margin Overview'>
      <style />
      <size maxheight='850' maxwidth='1250' minheight='850' minwidth='1250' />
      <zones>
        <zone h='100000' id='50' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='50000' id='51' name='Late-Delivery Map' w='50000' x='0' y='0' />
          <zone h='50000' id='52' name='Depot On-Time' w='50000' x='50000' y='0' />
          <zone h='50000' id='53' name='Margin Matrix' w='50000' x='0' y='50000' />
          <zone h='50000' id='54' name='Peak Trend' w='50000' x='50000' y='50000' />
        </zone>
      </zones>
    </dashboard>
  </dashboards>
  <windows>
    <window class='worksheet' name='Late-Delivery Map' />
    <window class='worksheet' name='Depot On-Time' />
    <window class='worksheet' name='Cost vs SLA Scatter' />
    <window class='worksheet' name='Margin Matrix' />
    <window class='worksheet' name='Peak Trend' />
    <window class='dashboard' maximized='true' name='Delivery &amp; Margin Overview' />
  </windows>
</workbook>
